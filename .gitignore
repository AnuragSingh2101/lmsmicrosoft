# Environment and secrets
.env
.env.*
!.env.example

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Test/coverage artifacts
.coverage
.coverage.*
htmlcov/

# Runtime logs and local databases
*.log
*.sqlite
*.sqlite3
instance/

# Local uploads/generated files
backend/uploads/thumbnails/*
backend/uploads/notes/*
backend/uploads/submissions/*
backend/uploads/certificates/*

# Keep upload folders in repo if needed
!backend/uploads/thumbnails/.gitkeep
!backend/uploads/notes/.gitkeep
!backend/uploads/submissions/.gitkeep
!backend/uploads/certificates/.gitkeep

# Editor/OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
